@startuml Control_Replication_Pipeline
' Налаштування темного преміального слайда 16:9
skinparam BackgroundColor #1E1E1E
skinparam DefaultFontName Arial
skinparam DefaultFontSize 11
skinparam packageStyle rectangle

' Стилізація назв контейнерів під темний фон
skinparam PackageFontColor #FFFFFF
skinparam PackageBorderColor #444444
skinparam PackageFontSize 13

' Стилізація плашок елементів
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #FFFFFF
    FontColor #000000
    RoundCorner 4
}

' Контрастні неонові стрілки для фокусу
skinparam ArrowColor #00e5ff
skinparam ArrowThickness 2

' Глобальний режим вирівнювання зліва направо
left to right direction

' 1. Оголошуємо перший пакет (Джерело подій)
package "1. ZeroCast Client (Capture)" as Client {
    rectangle "egui Event Loop\n<size:10><color:gray>[Перехоплення подій]</color></size>" as Egui
    rectangle "Input Mapper" as Mapper
    rectangle "RemoteInput Enum" as Enum
    rectangle "Bincode Serializer\n<size:10><color:gray>[Серіалізація Bincode]</color></size>" as Serializer
    rectangle "TLS Connector" as ClientTLS
}

' 2. Оголошуємо другий пакет (Мережевий транзит) - ТЕПЕР ВІН СУВОРO ПО ЦЕНТРУ
package "2. Транспорт" as Net {
    rectangle "TLS Secure Socket\n<size:10><color:gray>[Захищений TCP сокет]</color></size>" as Socket #e1f5fe
}

' 3. Оголошуємо третій пакет (Виконання на хості)
package "3. ZeroCast Server (Injection)" as Server {
    rectangle "TLS Acceptor\n<size:10><color:gray>[Розшифрування TLS 1.3]</color></size>" as ServerTLS
    rectangle "Bincode Deserializer" as Deserializer
    rectangle "Denormalization\n<size:10><color:gray>[Масштабування координат]</color></size>" as Denorm
    rectangle "Win32 SendInput API\n<size:10><color:gray>[Емуляція інпуту]</color></size>" as Win32
}

' ЖОРСТКА ФІКСАЦІЯ ПОРЯДКУ ПАКЕТІВ НА ОДНІЙ ЛІНІЇ (через приховані горизонтальні зв'язки)
Client -[hidden]-> Net
Net -[hidden]-> Server

' ЄДИНИЙ НАЙПРОСТІШИЙ ЛАНЦЮЖОК ДАНИХ (виключно через "->")
Egui -> Mapper
Mapper -> Enum
Enum -> Serializer
Serializer -> ClientTLS
ClientTLS -> Socket
Socket -> ServerTLS
ServerTLS -> Deserializer
Deserializer -> Denorm
Denorm -> Win32
@enduml