@startuml Zerocast_Security_Diagram
' Оптимізація під темний преміальний слайд 16:9
skinparam BackgroundColor #1E1E1E
skinparam DefaultFontName Arial
skinparam DefaultFontSize 11
skinparam packageStyle rectangle

' Стилізація колонок (картки на слайді)
skinparam PackageFontColor #FFFFFF
skinparam PackageBorderColor #444444
skinparam PackageFontSize 13

' Стилізація плашек елементів
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #FFFFFF
    FontColor #000000
    RoundCorner 4
}

' Контрастні неонові стрілки та чіткий білий текст біля них
skinparam ArrowColor #00e5ff
skinparam ArrowFontColor #FFFFFF
skinparam ArrowThickness 2

' Глобальний режим вирівнювання зліва направо
left to right direction

' КОЛОНКА 1: Клієнтська частина (Вертикальний стек)
package "1. ZeroCast Client (Guest)" as Client {
    rectangle "egui Auth UI\n<size:10><color:gray>[Формування AuthRequest]</color></size>" as ClientUi
    rectangle "Input Service\n<size:10><color:gray>[Захоплення подій введення]</color></size>" as ClientInput
    rectangle "GStreamer Receiver\n<size:10><color:gray>[Рендеринг текстур у VRAM]</color></size>" as ClientMedia

    ClientUi -[hidden]down-> ClientInput
    ClientInput -[hidden]down-> ClientMedia
}

' КОЛОНКА 2: Мережевий шлюз (Ізольовані порти)
package "2. Захищений LAN Тракт" as Network {
    rectangle "Порт: 8080 (TCP)\n<size:10><color:gray>Динамічний Handshake</color></size>" as PortAuth #F5F5F5
    rectangle "Порт: 8081 (TCP/TLS)\n<size:10><color:blue>**Шифрування TLS 1.3**</color></size>" as PortInput #E1F5FE
    rectangle "Порт: 5000 (UDP/SRT)\n<size:10><color:red>**Апаратний AES-128**</color></size>" as PortMedia #FFE0B2

    PortAuth -[hidden]down-> PortInput
    PortInput -[hidden]down-> PortMedia
}

' КОЛОНКА 3: Серверна частина (Вертикальний стек)
package "3. ZeroCast Server (Host)" as Server {
    rectangle "SessionStore\n<size:10><color:gray>[tokio::Mutex станів]</color></size>" as Store
    rectangle "Input Replicator\n<size:10><color:gray>[Валідація & Logic Firewall]</color></size>" as ServerInput
    rectangle "GStreamer Producer\n<size:10><color:gray>[Каптуринг DXGI / NVENC]</color></size>" as ServerMedia

    Store -[hidden]down-> ServerInput
    ServerInput -[hidden]down-> ServerMedia
}

' ЖОРСТКА ФІКСАЦІЯ ПОРЯДКУ КОЛОНОК НА СЛАЙДІ
Client -[hidden]-> Network
Network -[hidden]-> Server

' РЯДОК 1: Авторизація (Потік йде праворуч)
ClientUi -right-> PortAuth : AuthRequest
PortAuth -right-> Store : Валідація

' РЯДОК 2: Керування (Потік йде праворуч)
ClientInput -right-> PortInput : TLS-потік
PortInput -right-> ServerInput : Реплікація

' РЯДОК 3: Відеопотік (Логічно йде від Сервера до Клієнта, але без руйнування сітки)
ClientMedia <-right- PortMedia : VRAM Стрім
PortMedia <-right- ServerMedia : SRT-потік
@enduml