@startuml Direct_Media_Pipeline
' Оптимізація під темний преміальний слайд 16:9
skinparam BackgroundColor #1E1E1E
skinparam DefaultFontName Arial
skinparam DefaultFontSize 11
skinparam packageStyle rectangle

' Стилізація колонок (картки на слайді)
skinparam PackageFontColor #FFFFFF
skinparam PackageBorderColor #444444
skinparam PackageFontSize 13

' Стилізація плашок елементів
skinparam rectangle {
    BackgroundColor #FFFFFF
    BorderColor #FFFFFF
    FontColor #000000
    RoundCorner 4
}

' Контрастні неонові стрілки для фокусу
skinparam ArrowColor #00e5ff
skinparam ArrowThickness 2

' Глобальний режим вирівнювання зліва направо
left to right direction

' КОЛОНКА 1
package "1. Захоплення (VRAM Context)" as VRAM {
    rectangle "d3d11screencapturesrc\n<size:10><color:gray>[Захоплення у VRAM]</color></size>" as src
    rectangle "queue (leaky=downstream)\n<size:10><color:gray>[Захист від накопичення лагів]</color></size>" as raw_q
    rectangle "d3d11scale" as scale
    rectangle "d3d11convert" as convert
    rectangle "capsfilter (D3D11, NV12)" as gpu_caps
}

' КОЛОНКА 2
package "2. Міст пам'яті / Препроцесинг" as Bridge {
    rectangle "d3d11download\n<size:10><color:gray>[Копіювання VRAM -> RAM]</color></size>" as download
    rectangle "capsfilter (System, NV12)" as cpu_caps
    rectangle "videoconvert" as vconv
}

' КОЛОНКА 3
package "3. Апаратне кодування" as HwEnc {
    rectangle "nvh264enc\n(Zero-latency=true, bframes=0)\n<size:10><color:gray>[Стиснення H.264 без буферизації]</color></size>" as encoder
    rectangle "h264parse\n(config-interval=1)" as parse
}

' КОЛОНКА 4
package "4. Мережева передача" as NetTrans {
    rectangle "queue (max-size-buffers=3)" as net_q
    rectangle "srtsink\n(sync=false, latency=20ms)\n<size:10><color:gray>[Трансляція SRT через UDP]</color></size>" as sink
}

' ЖОРСТКА ФІКСАЦІЯ ПОРЯДКУ ПАКЕТІВ НА ОДНІЙ ЛІНІЇ
VRAM -[hidden]-> Bridge
Bridge -[hidden]-> HwEnc
HwEnc -[hidden]-> NetTrans

' ЄДИНИЙ НАЙПРОСТІШИЙ ЛАНЦЮЖОК ДАНИХ (виключно через "->")
src -> raw_q
raw_q -> scale
scale -> convert
convert -> gpu_caps
gpu_caps -> download
download -> cpu_caps
cpu_caps -> vconv
vconv -> encoder
encoder -> parse
parse -> net_q
net_q -> sink
@enduml